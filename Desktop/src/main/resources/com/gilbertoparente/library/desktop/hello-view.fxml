<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="25.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gilbertoparente.library.desktop.HelloController"
      styleClass="main-content-area" prefHeight="400.0" prefWidth="600.0">

    <stylesheets>
        <URL value="@/style.css" />
    </stylesheets>

    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <VBox alignment="CENTER" spacing="10.0">
        <Label text="Bem-vindo ao Sistema" styleClass="titulo-principal"/>
        <Label text="Biblioteca Científica Digital" styleClass="subtitulo"/>
    </VBox>

    <Separator maxWidth="300.0" opacity="0.3" />

    <Label fx:id="welcomeText" styleClass="label" text="Pronto para começar?" />

    <HBox alignment="CENTER" spacing="15.0">
        <Button text="Iniciar Painel" onAction="#onHelloButtonClick" styleClass="button-success" prefWidth="150.0" />
        <Button text="Sair" styleClass="button-secondary" prefWidth="100.0" />
    </HBox>
</VBox>