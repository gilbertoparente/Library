<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" prefWidth="900" prefHeight="600" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gilbertoparente.library.desktop.CommentsController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Moderação de Comentários" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <TreeTableView fx:id="commentsTreeTable" VBox.vgrow="ALWAYS">
        <columns>
            <TreeTableColumn fx:id="colContent" text="Comentário / Resposta" prefWidth="400" />
            <TreeTableColumn fx:id="colArticle" text="Artigo" prefWidth="150" />
            <TreeTableColumn fx:id="colUser" text="Utilizador" prefWidth="120" />
            <TreeTableColumn fx:id="colDate" text="Data" prefWidth="120" />
            <TreeTableColumn fx:id="colStatus" text="Estado" prefWidth="100" />
        </columns>
        <columnResizePolicy><TreeTableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
    </TreeTableView>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Aprovar ✅" onAction="#handleApprove" style="-fx-background-color: #2980b9; -fx-text-fill: white;" />
        <Button text="Ocultar 🚫" onAction="#handleHide" style="-fx-background-color: #2980b9;" />
        <Button text="Eliminar 🗑️" onAction="#handleDelete" style="-fx-background-color: #2980b9; -fx-text-fill: white;" />
        <Separator orientation="VERTICAL" />
        <Button text="Fechar" onAction="#handleClose" />
    </HBox>
</VBox>