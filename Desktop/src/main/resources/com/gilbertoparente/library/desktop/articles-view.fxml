<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gilbertoparente.library.desktop.ArticlesController"
      prefWidth="1100.0" prefHeight="700.0" styleClass="main-content-area">

    <stylesheets>
        <URL value="@/style.css" />
    </stylesheets>

    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>

    <VBox spacing="5.0">
        <Label text="Biblioteca Científica" styleClass="titulo-principal"/>
        <Label text="Gestão de repositório e pesquisa avançada de artigos." styleClass="subtitulo"/>
    </VBox>

    <Separator opacity="0.4" />

    <HBox spacing="15.0" alignment="CENTER_LEFT" styleClass="barra-filtros">
        <padding>
            <Insets bottom="10" left="15" right="15" top="10" />
        </padding>

        <VBox spacing="5">
            <Label text="Pesquisa Geral:" styleClass="label-pequena"/>
            <TextField fx:id="txtSearch" promptText="Título, Autor ou DOI..." prefWidth="350.0" />
        </VBox>

        <VBox spacing="5">
            <Label text="Estado:" styleClass="label-pequena"/>
            <ComboBox fx:id="comboFilterStatus" prefWidth="150.0" promptText="Todos" />
        </VBox>

        <VBox spacing="5">
            <Label text="Tipo de Artigo:" styleClass="label-pequena"/>
            <ComboBox fx:id="comboTypeFilter" prefWidth="150.0" promptText="Tipo de Artigo" styleClass="combo-box-filtro" />
        </VBox>

    </HBox>

    <!-- SplitPane para dividir Tabela e Detalhes -->
    <SplitPane dividerPositions="0.6" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
        <items>
            <TableView fx:id="articlesTable">
                <columns>
                    <TableColumn fx:id="titleColumn" prefWidth="250.0" text="Título" />
                    <TableColumn fx:id="authorsColumn" prefWidth="180.0" text="Autor(es)" />
                    <TableColumn fx:id="thematicsColumn" prefWidth="150.0" text="Temática" />
                    <TableColumn fx:id="statusColumn" prefWidth="110.0" text="Estado" />
                    <TableColumn fx:id="priceColumn" prefWidth="100.0" text="Preço Base" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
                <placeholder>
                    <Label text="Nenhum artigo encontrado." />
                </placeholder>
            </TableView>


            <ScrollPane fitToWidth="true" style="-fx-background-color: white; -fx-background-radius: 5;">
                <VBox fx:id="detailsContainer" spacing="10">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="Selecione um artigo para ver os detalhes." style="-fx-text-fill: #95a5a6; -fx-font-style: italic;"/>
                </VBox>
            </ScrollPane>
        </items>
    </SplitPane>

    <HBox alignment="CENTER_RIGHT" spacing="12.0">
        <Region HBox.hgrow="ALWAYS" />

        <Button onAction="#handleAddArticle" text="Novo Artigo" styleClass="button-success" prefWidth="130.0" />
        <Button onAction="#handleEditArticle" text="Editar" styleClass="button-secondary" prefWidth="100.0" />
        <Button onAction="#handleDeleteArticle" text="Eliminar" styleClass="button-danger" prefWidth="100.0" />
    </HBox>
</VBox>