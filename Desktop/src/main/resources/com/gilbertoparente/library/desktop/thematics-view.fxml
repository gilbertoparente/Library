<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gilbertoparente.library.desktop.ThematicsController"
      styleClass="main-content-area">

    <stylesheets>
        <URL value="@/style.css" />
    </stylesheets>

    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>

    <VBox spacing="5.0">
        <Label text="Categorias e Temáticas" styleClass="titulo-principal" />
        <Label text="Organize os artigos científicos por áreas de conhecimento." styleClass="subtitulo" />
    </VBox>

    <Separator opacity="0.4" />

    <HBox spacing="15.0" alignment="CENTER_LEFT" styleClass="barra-filtros">
        <padding>
            <Insets bottom="10" left="15" right="15" top="10" />
        </padding>

        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Procurar Temática:" styleClass="label-pequena"/>
            <TextField fx:id="txtSearch" promptText="Escreva o nome da categoria..." maxWidth="Infinity" />
        </VBox>

        <VBox alignment="BOTTOM_CENTER" spacing="10">
            <HBox spacing="10">
                <Button text="Pesquisar" onAction="#handleSearch1" styleClass="button-info" />
                <Button text="Limpar" onAction="#handleClearSearch1" styleClass="button-secondary" />
            </HBox>
        </VBox>
    </HBox>

    <TableView fx:id="thematicsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="descColumn" prefWidth="400.0" text="Descrição da Temática / Área de Conhecimento" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <placeholder>
            <Label text="Nenhuma temática encontrada. Utilize o botão 'Nova Temática' para começar." />
        </placeholder>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="12.0">
        <Label text="Gestão de Itens:" styleClass="label-pequena" />
        <Region HBox.hgrow="ALWAYS" />

        <Button onAction="#handleAddThematic" prefHeight="35.0" prefWidth="150.0"
                text="Nova Temática" styleClass="button-success" />

        <Button onAction="#handleEditThematic" prefHeight="35.0" prefWidth="100.0"
                text="Editar" styleClass="button-secondary" />

        <Button onAction="#handleDeleteThematic" prefHeight="35.0" prefWidth="100.0"
                text="Eliminar" styleClass="button-danger" />
    </HBox>
</VBox>