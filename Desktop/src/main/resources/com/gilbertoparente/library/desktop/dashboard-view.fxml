<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gilbertoparente.library.desktop.AdminDashboardController">

    <stylesheets>
        <URL value="@/style.css" />
    </stylesheets>

    <left>
        <VBox prefWidth="260.0" spacing="10.0" styleClass="sidebar">
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="30.0" />
            </padding>

            <VBox alignment="CENTER" spacing="15.0">
                <ImageView fx:id="logoView" fitHeight="80.0" fitWidth="180.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@/images/FullLogo_Transparent.png" />
                    </image>
                </ImageView>

                <VBox alignment="CENTER" spacing="3">
                    <Label fx:id="lblAdminName" text="Administrador" styleClass="label-admin-name" />
                    <Label text="Painel de Controlo" styleClass="label-admin-subtitle" />
                </VBox>
                <Separator opacity="0.2" prefWidth="200.0" />
            </VBox>

            <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                <Button maxWidth="Infinity" onAction="#showHomeSection" styleClass="menu-button" text="Início / Estatísticas" />
                <Button maxWidth="Infinity" onAction="#showUsersSection" styleClass="menu-button" text="Gerir Utilizadores" />
                <Button maxWidth="Infinity" onAction="#showArticlesSection" styleClass="menu-button" text="Gerir Artigos" />
                <Button maxWidth="Infinity" onAction="#showThematicsSection" styleClass="menu-button" text="Gerir Temáticas" />
                <Button maxWidth="Infinity" onAction="#showPurchasesSection" styleClass="menu-button" text="Gerir Compras" />
                <Button maxWidth="Infinity" onAction="#showCommentsSection" styleClass="menu-button" text="Ver Comentários" />
            </VBox>

            <Separator opacity="0.2" />

            <Button maxWidth="Infinity" onAction="#handleLogout" text="Terminar Sessão" styleClass="button-logout" />
        </VBox>
    </left>

    <center>
        <AnchorPane fx:id="mainContent" styleClass="main-content-area">
            <Label text="A carregar sistema..." styleClass="subtitulo" />
        </AnchorPane>
    </center>
</BorderPane>