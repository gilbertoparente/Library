<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.gilbertoparente.library.desktop.AdminDashboardController">
    <top>
        <HBox spacing="10" style="-fx-background-color: #333;">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label text="Library Admin System" style="-fx-text-fill: white; -fx-font-size: 18;"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Logout" onAction="#handleLogout" />
        </HBox>
    </top>
    <center>
        <TabPane>
            <Tab text="Artigos" closable="false">
                <VBox spacing="10">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <TableView fx:id="articlesTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="titleColumn" text="Título" prefWidth="300"/>
                            <TableColumn fx:id="priceColumn" text="Preço" prefWidth="100"/>
                        </columns>
                    </TableView>
                    <Button text="Recarregar" onAction="#refreshArticles" />
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>