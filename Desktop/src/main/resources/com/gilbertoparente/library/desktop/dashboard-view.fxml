<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<BorderPane prefHeight="600.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gilbertoparente.library.desktop.AdminDashboardController">

    <left>
        <VBox prefWidth="250.0" spacing="15.0" style="-fx-background-color: #2c3e50;">
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="30.0" />
            </padding>
            <children>
                <Label text="LIBRARY ADMIN" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </Label>

                <HBox alignment="CENTER" prefWidth="250.0">
                    <padding>
                        <Insets top="20.0" bottom="20.0" />
                    </padding>
                    <children>
                        <ImageView fx:id="logoView" fitHeight="130.0" fitWidth="200.0"
                                   pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@/images/Logo_Transparent.png"/>
                            </image>
                        </ImageView>
                    </children>
                </HBox>

                <Separator opacity="0.3" />

                <Button fx:id="btnDashboard" onAction="#showHomeSection" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" text="👤 Dashboard">
                    <font><Font size="14.0" /></font></Button>

                <Button maxWidth="Infinity" onAction="#showUsersSection" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" text="👤 Gerir Utilizadores">
                    <font><Font size="14.0" /></font></Button>

                <Button maxWidth="Infinity" onAction="#showArticlesSection" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" text="📚 Gerir Artigos">
                    <font><Font size="14.0" /></font></Button>

                <Button maxWidth="Infinity" onAction="#showThematicsSection" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" text="🏷️ Gerir Temáticas">
                    <font><Font size="14.0" /></font></Button>

                <Button maxWidth="Infinity" onAction="#showPurchasesSection" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" text="💰 Gerir Compras">
                    <font><Font size="14.0" /></font></Button>

                <Button maxWidth="Infinity" onAction="#showCommentsSection" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" text="💬 Ver Comentários">
                    <font><Font size="14.0" /></font></Button>

                <Region VBox.vgrow="ALWAYS" />

                <Button maxWidth="Infinity" onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Sair (Logout)">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
            </children>
        </VBox>
    </left>

    <center>
        <AnchorPane fx:id="mainContent" style="-fx-background-color: #ecf0f1;">

        </AnchorPane>
    </center>
</BorderPane>